{
  "name": "campuscart-india",
  "version": "1.0.0",
  "description": "CampusCart India - The Ultimate E-commerce Destination for Indian Students",
  "main": "server/index.js",
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "postinstall": "npm-run-all --parallel install:*",
    "install:client": "cd client && npm install",
    "install:server": "cd server && npm install",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/surajchaurasiya/CampusCart.git"
  },
  "keywords": [
    "node",
    "express",
    "mongoose",
    "react",
    "redux",
    "redux-thunk",
    "webpack"
  ],
  "author": "Suraj Chaurasiya (https://github.com/surajchaurasiya)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/surajchaurasiya/CampusCart/issues"
  },
  "homepage": "https://github.com/surajchaurasiya/CampusCart#readme",
  "devDependencies": {
    "cross-env": "^5.2.1",
    "npm-run-all": "^4.1.5"
  }
}